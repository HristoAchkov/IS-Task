@using IS_Task.Models.ResponseModels
@model List<GetAllOrdersResponseModel>
@{
    ViewData["Title"] = "Orders";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Order History</h1>
    <p class="text-gray-500 mt-1">All your past orders</p>
</div>

@foreach (var order in Model)
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 max-w-2xl mx-auto mt-5 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3 bg-gray-50 border-b border-gray-200">
            <span class="font-semibold text-gray-700">Order #@order.Id</span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">@order.Status</span>
        </div>
        <div class="px-5 py-4">
            <p class="text-sm text-gray-400 mb-4">@order.CreatedAt.ToString("dd MMM yyyy HH:mm")</p>
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider border-b border-gray-100">
                        <th class="pb-2">Product</th>
                        <th class="pb-2">Price</th>
                        <th class="pb-2">Qty</th>
                        <th class="pb-2">Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in order.OrderItems)
                    {
                        <tr class="text-gray-700">
                            <td class="py-2">@item.ProductName</td>
                            <td class="py-2">@item.Price.ToString("C")</td>
                            <td class="py-2">@item.Quantity</td>
                            <td class="py-2">@item.LineTotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="flex items-center justify-between px-5 py-3 bg-gray-50 border-t border-gray-200">
            <span class="font-semibold text-gray-700">Total Amount</span>
            <span class="font-bold text-gray-900">@order.TotalAmount.ToString("C")</span>
        </div>
    </div>
}

<div class="text-center mt-8">
    <a asp-action="Index" asp-controller="Product" class="inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
        ← Back to Products
    </a>
</div>