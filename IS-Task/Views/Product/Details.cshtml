@using IS_Task.Models.ResponseModels
@model GetProductByIdResponseModel
@{
    ViewData["Title"] = "Product Details";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-1">@Model.Name</h1>
        <p class="text-gray-500 mb-3">@Model.Description</p>
        <p class="text-xl font-semibold text-gray-900 mb-1">@Model.Price.ToString("C")</p>
        
        <div class="flex gap-3">
            @if (User.IsInRole(DataConstants.AdminConstant))
            {
                <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id"
                   class="px-4 py-2 rounded-lg bg-amber-500 text-white text-sm font-medium hover:bg-amber-600 transition">
                    Edit
                </a>
                <form asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="inline">
                    <button type="submit" onclick="return confirm('Are you sure?')"
                            class="px-4 py-2 rounded-lg bg-red-50 text-red-600 text-sm font-medium hover:bg-red-100 transition border border-red-200">
                        Delete
                    </button>
                </form>
                <a asp-area="Admin" asp-controller="Product" asp-action="GetAllProductsAdmin"
                   class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
                    ← Back
                </a>
            }
            else
            {
                <a asp-area="" asp-controller="Product" asp-action="Index"
                   class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
                    ← Back
                </a>
            }
        </div>
    </div>
</div>