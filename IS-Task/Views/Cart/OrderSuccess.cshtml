@{
    ViewData["Title"] = "Order Placed";
}

<div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="text-5xl mb-4">🎉</div>
    <h1 class="text-4xl font-bold text-gray-900 mb-3">Order Placed Successfully!</h1>
    <p class="text-gray-500 text-lg mb-8">Thank you for your order. We'll be in touch soon.</p>
    <a asp-controller="Product" asp-action="Index"
       class="inline-flex items-center px-6 py-3 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition shadow-sm">
        Continue Shopping
    </a>
</div>