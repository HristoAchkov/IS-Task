@using IS_Task.Models.RequestModels
@model PostCheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="max-w-lg mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Checkout</h1>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <form asp-action="Checkout" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 rounded-lg px-4 py-2"></div>
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="FamilyName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="FamilyName" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="FamilyName" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Address" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Address" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Phone" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Email" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="flex-1 px-5 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition shadow-sm">
                    Place Order
                </button>
                <a asp-action="Index"
                   class="px-5 py-2.5 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
                    Back to Cart
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}