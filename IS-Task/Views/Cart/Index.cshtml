@using IS_Task.Models.ResponseModels
@model GetCartResponseModel
@{
    ViewData["Title"] = "Cart";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Your Cart</h1>
</div>

@if (!Model.CartItems.Any())
{
    <div class="text-center py-16 text-gray-500">
        <div class="text-5xl mb-4">🛒</div>
        <p class="text-lg mb-6">Your cart is empty.</p>
        <a asp-controller="Product" asp-action="Index"
           class="inline-flex items-center px-5 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition">
            Continue Shopping
        </a>
    </div>
}
else
{
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                    <th class="px-4 py-3">Product</th>
                    <th class="px-4 py-3">Description</th>
                    <th class="px-4 py-3">Category</th>
                    <th class="px-4 py-3">Price</th>
                    <th class="px-4 py-3">Qty</th>
                    <th class="px-4 py-3">Total</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model.CartItems)
                {
                    <tr class="text-gray-700 hover:bg-gray-50 transition">
                        <td class="px-4 py-3 font-medium">@item.ProductName</td>
                        <td class="px-4 py-3 text-gray-500">@item.ProductDescription</td>
                        <td class="px-4 py-3">@item.CategoryName</td>
                        <td class="px-4 py-3">@item.Price.ToString("C")</td>
                        <td class="px-4 py-3">@item.Quantity</td>
                        <td class="px-4 py-3 font-medium">@item.LineTotal.ToString("C")</td>
                        <td class="px-4 py-3">
                            <form asp-action="RemoveFromCart" asp-route-cartItemId="@item.CartItemId" method="post">
                                <button type="submit" onclick="return confirm('Remove item?')"
                                        class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 transition">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="bg-gray-50 border-t border-gray-200">
                <tr>
                    <td colspan="5" class="px-4 py-3 text-right font-semibold text-gray-700">Order Total:</td>
                    <td class="px-4 py-3 font-bold text-gray-900">@Model.Total.ToString("C")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="flex gap-3 mt-5">
        <a asp-controller="Product" asp-action="Index"
           class="inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
            ← Continue Shopping
        </a>
        <a asp-controller="Cart" asp-action="Checkout"
           class="inline-flex items-center px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition shadow-sm">
            Checkout →
        </a>
    </div>
}