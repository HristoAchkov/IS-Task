@using IS_Task.Areas.Admin.Models.ResponseModels
@using IS_Task.Models.ResponseModels
@model GetCategoryByIdResponseModel
@{
    ViewData["Title"] = "Category Details";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">@Model.Name</h1>
        <p class="text-gray-500 mb-6">@Model.Description</p>
        <div class="flex gap-3">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="px-4 py-2 rounded-lg bg-amber-500 text-white text-sm font-medium hover:bg-amber-600 transition">
                Edit
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="inline">
                <button type="submit" onclick="return confirm('Are you sure?')"
                        class="px-4 py-2 rounded-lg bg-red-50 text-red-600 text-sm font-medium hover:bg-red-100 transition border border-red-200">
                    Delete
                </button>
            </form>
            <a asp-action="GetAllCategories"
               class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
                ← Back
            </a>
        </div>
    </div>
</div>