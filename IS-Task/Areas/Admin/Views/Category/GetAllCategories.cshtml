@using IS_Task.Models.ResponseModels
@model List<GetAllCategoriesResponseModel>
@{
    ViewData["Title"] = "GetAllCategories";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Categories</h1>
    <a asp-action="Create"
       class="inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition shadow-sm">
        + Add Category
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3">Description</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var category in Model)
            {
                <tr class="text-gray-700 hover:bg-gray-50 transition">
                    <td class="px-4 py-3 font-medium">@category.Name</td>
                    <td class="px-4 py-3 text-gray-500">@category.Description</td>
                    <td class="px-4 py-3">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">@category.Status</span>
                    </td>
                    <td class="px-4 py-3">
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="flex items-center gap-2">
                                <a asp-action="Details" asp-route-id="@category.Id"
                                   class="px-2.5 py-1 rounded text-xs font-medium bg-sky-50 text-sky-700 hover:bg-sky-100 transition">Details</a>
                                <a asp-action="Edit" asp-route-id="@category.Id"
                                   class="px-2.5 py-1 rounded text-xs font-medium bg-amber-50 text-amber-700 hover:bg-amber-100 transition">Edit</a>
                                <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="inline">
                                    <button type="submit" onclick="return confirm('Are you sure?')"
                                            class="px-2.5 py-1 rounded text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 transition">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>