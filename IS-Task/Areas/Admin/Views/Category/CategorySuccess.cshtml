@{
    ViewData["Title"] = "CategorySuccess";
}

<div class="flex flex-col items-center justify-center min-h-[60vh]">
    <div class="bg-white rounded-2xl shadow-lg p-10 flex flex-col items-center gap-4 max-w-md w-full">
        <div class="text-green-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-800">Success!</h1>
        <p class="text-gray-500 text-center">Your category has been successfully created.</p>
        <div class="flex gap-3 mt-2">
            <a asp-action="Create"
               class="px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition">
                Create Another
            </a>
            <a asp-action="GetAllCategories"
               class="px-5 py-2 rounded-lg border border-gray-200 text-gray-700 text-sm font-medium hover:bg-gray-100 transition">
                Back to List
            </a>
        </div>
    </div>
</div>