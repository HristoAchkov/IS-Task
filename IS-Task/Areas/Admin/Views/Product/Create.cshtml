@using IS_Task.Areas.Admin.Models
@using IS_Task.Areas.Admin.Models.RequestModels
@using IS_Task.Models.RequestModels
@model CreateProductModel
@{
    ViewData["Title"] = "Create Product";
}

<div class="max-w-lg mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-1">Create Product</h1>
    <p class="text-gray-500 mb-6">Add a new product to the store</p>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <form asp-action="Create" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 rounded-lg px-4 py-2"></div>
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Description" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Description" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Price" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <span asp-validation-for="Price" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <select asp-for="CategoryId"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white">
                    <option value="">-- Select Category --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId ? "selected" : null)">
                            @cat.Name
                        </option>
                    }
                </select>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="px-5 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition shadow-sm">
                    Create
                </button>
                <a asp-action="GetAllProductsAdmin"
                   class="px-5 py-2.5 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}